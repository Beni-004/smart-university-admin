# Database Configuration (Required)
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/university_db

# LLM Services (At least ONE required)
# Groq API (Optional - for fast cloud-based SQL generation)
GROQ_API_KEY=your_groq_api_key_here

# Ollama (Optional - for local SQL generation)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=sqlcoder:15b
